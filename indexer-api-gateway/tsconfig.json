{
    "compilerOptions": {
        "declaration": true,
        "emitDecoratorMetadata": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "lib": [
            "ES2023"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noUnusedLocals": true,
        "noUnusedParameters": false,
        "outDir": "dist/",
        "paths": {
            "#decorators": [
                "./src/decorators/index.js"
            ],
            "#dto": [
                "./src/dto/index.js"
            ]
        },
        "rootDir": "./src",
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": false,
        "target": "ES2023"
    },
    "exclude": [
        "node_modules",
        "public",
        "dist"
    ],
    "include": [
        "src/**/*"
    ]
}