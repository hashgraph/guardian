{
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "detect-secrets": "^1.0.6",
        "eslint": "^10.5.0",
        "eslint-plugin-unicorn": "^68.0.0",
        "globals": "^17.7.0",
        "typescript-eslint": "^8.62.0"
    },
    "engines": {
        "node": ">=24.15.0"
    },
    "name": "guardian",
    "packageManager": "yarn@4.16.0",
    "private": true,
    "resolutions": {
        "@mattrglobal/bls12381-key-pair": "2.0.0",
        "@mattrglobal/bbs-signatures": "2.0.0"
    },
    "scripts": {
        "detect-secrets": "detect-secrets-launcher --word-list exclude-secrets.txt k8s-manifests/**/* */src/**.ts **/.env*",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "publish-policies": "guardian-cli publish-policies \"Methodology Library\" -c \"configs/automatic-publish-policies.config.json\" -o \"published-policies.txt\"",
        "clean": "find . -type d \\( -name dist -o -name node_modules \\) -prune -exec rm -rf {} +"
    },
    "version": "3.6.0",
    "workspaces": [
        "interfaces",
        "common",
        "ai-service",
        "analytics-service",
        "api-gateway",
        "application-events",
        "auth-service",
        "guardian-cli",
        "guardian-service",
        "logger-service",
        "mrv-sender",
        "notification-service",
        "policy-service",
        "queue-service",
        "topic-listener-service",
        "topic-viewer",
        "tree-viewer",
        "worker-service",
        "indexer-interfaces",
        "indexer-common",
        "indexer-api-gateway",
        "indexer-service",
        "indexer-worker-service"
    ]
}
