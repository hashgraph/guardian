{
    "compilerOptions": {
        "emitDecoratorMetadata": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "lib": [
            "ES2023"
        ],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "outDir": "dist/",
        "paths": {
            "@analytics": [
                "./src/analytics/index"
            ],
            "@api/*": [
                "./src/api/*"
            ],
            "@auth/*": [
                "./src/auth/*"
            ],
            "@database-modules": [
                "./src/database-modules/index"
            ],
            "@document-loader/*": [
                "./src/document-loader/*"
            ],
            "@entity/*": [
                "./src/entity/*"
            ],
            "@hedera-modules": [
                "./src/hedera-modules/index"
            ],
            "@helpers/*": [
                "./src/helpers/*"
            ],
            "@policy-engine/*": [
                "./src/policy-engine/*"
            ],
            "@subscribers/*": [
                "./src/subscribers/*"
            ]
        },
        "rootDir": "./src",
        "skipLibCheck": true,
        "sourceMap": false,
        "strict": false,
        "target": "ES2023"
    },
    "exclude": [
        "node_modules"
    ],
    "include": [
        "src/**/*",
        "../interfaces/src/type/TopicType.ts"
    ]
}