# ============================================
# Sustainable Explorer - Environment Configuration
# Hedera Mirror Node + IPFS Data Retrieval
# ============================================

# --- Hedera Network ---
# Worker: single network this instance syncs from (one worker process per network).
# API: used as fallback if HEDERA_NETWORKS is not set.
HEDERA_NET=mainnet
HEDERA_MIRROR_NODE_URL=

# API: comma-separated list of networks this API instance exposes.
# Each network is served from its own database (see resolveDatabaseName).
# The first entry is used as the default network.
# Example: HEDERA_NETWORKS=mainnet,testnet
HEDERA_NETWORKS=mainnet,testnet

# Seed topic ID for bootstrapping a fresh system (optional).
# If topic_cache is empty on startup, this topic is auto-inserted.
# Leave blank to use the default root topic for the selected network:
#
#   | Network    | Default Topic ID |
#   |------------|------------------|
#   | Mainnet    | 0.0.1368856      |
#   | Testnet    | 0.0.1960         |
#   | Previewnet | 0.0.10071        |
#
SEED_TOPIC_ID=

# Registry allowlist — comma-separated topic IDs. When set, only these
# topics (discovered from seed-topic messages) are followed. Deeper
# child topics within allowed registries are always discovered.
# Leave blank to discover all registries (default).
# Example: ONLY_REGISTRY_TOPIC=0.0.12345,0.0.67890
ONLY_REGISTRY_TOPIC=

# --- IPFS ---
# Comma-separated list of public IPFS gateways to race in parallel.
# The first gateway to respond wins; slower ones are aborted automatically.
# Recommended fast gateways (roughly ordered by reliability):
#   https://ipfs.hedera.com/ipfs/          — Hedera-operated, good for Guardian content
#   https://w3s.link/ipfs/                 — Storacha (Cloudflare CDN), fast for public CIDs
#   https://dweb.link/ipfs/                — Protocol Labs
#   https://ipfs.io/ipfs/                  — Protocol Labs (same infra as dweb.link)
#   https://gateway.pinata.cloud/ipfs/     — Pinata public (unauthenticated, rate-limited)
#   https://ipfs.filebase.io/ipfs/         — Filebase public gateway
IPFS_GATEWAYS=https://ipfs.hedera.com/ipfs/,https://w3s.link/ipfs/,https://dweb.link/ipfs/,https://gateway.pinata.cloud/ipfs/

# Per-gateway authentication tokens for priority/rate-limit-bypass access.
# Format: <gateway-url>::<token>,<gateway-url2>::<token2>
# The gateway URL must exactly match one of the entries in IPFS_GATEWAYS above.
# Two formats supported:
#   url::token                  → Authorization: Bearer <token>   (default for most gateways)
#   url::header-name::token     → <header-name>: <token>          (explicit — use for Pinata)
# Pinata dedicated gateway example (uses x-pinata-gateway-token header):
#   IPFS_GATEWAY_TOKENS=https://your-name.mypinata.cloud/ipfs/::x-pinata-gateway-token::YOUR_GATEWAY_TOKEN
#
# --- Pinata dedicated gateway (recommended for priority access) ---
# 1. Sign up at https://pinata.cloud and create a dedicated gateway
#    (e.g. https://your-name.mypinata.cloud/ipfs/)
# 2. Generate a Gateway API key in Pinata dashboard → API Keys
# 3. Add the dedicated gateway to IPFS_GATEWAYS, then add the token here:
# Example:
#   IPFS_GATEWAYS=https://your-name.mypinata.cloud/ipfs/,https://w3s.link/ipfs/,...
#   IPFS_GATEWAY_TOKENS=https://your-name.mypinata.cloud/ipfs/::YOUR_PINATA_GATEWAY_TOKEN
#
# Leave blank if all gateways in IPFS_GATEWAYS are public/unauthenticated.
IPFS_GATEWAY_TOKENS=

IPFS_FETCH_TIMEOUT=180000

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=sustainable_explorer
DB_USER=explorer
DB_PASSWORD=explorer_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redict (Redis-compatible cache) ---
REDICT_HOST=localhost
REDICT_PORT=6379
REDICT_PASSWORD=
REDICT_DB=0
REDICT_KEY_PREFIX=se:

# --- Worker Horizontal Scaling ---
# Comma-separated queue names this instance should process.
# Leave empty to process ALL queues (single-instance mode).
# Supports glob patterns: "mirror-node-*" matches all mirror-node queues.
#
# Example horizontal scaling deployment:
#   Instance 1: WORKER_QUEUES=mirror-node-topics,mirror-node-messages
#   Instance 2: WORKER_QUEUES=ipfs-files,mirror-node-tokens
#   Instance 3: WORKER_QUEUES=maintenance-*
WORKER_QUEUES=

# --- Worker Concurrency (per instance) ---
WORKER_TOPIC_CONCURRENCY=5
WORKER_MESSAGE_CONCURRENCY=10
WORKER_TOKEN_CONCURRENCY=2
WORKER_IPFS_CONCURRENCY=3

# --- BullMQ Job Retention ---
# Number of completed/failed job records kept in Redis per queue.
# Higher values improve visibility in bull-board but grow Redis memory.
# For high-volume queues (topic-sync, message-parse) reduce these significantly
# if Redis memory becomes a concern (e.g. TOPIC_SYNC_REMOVE_ON_COMPLETE=100).
TOPIC_SYNC_REMOVE_ON_COMPLETE=1000
TOPIC_SYNC_REMOVE_ON_FAIL=5000
MESSAGE_PARSE_REMOVE_ON_COMPLETE=1000
MESSAGE_PARSE_REMOVE_ON_FAIL=5000
IPFS_FETCH_REMOVE_ON_COMPLETE=500
IPFS_FETCH_REMOVE_ON_FAIL=2000
POLICY_DECODE_REMOVE_ON_COMPLETE=500
POLICY_DECODE_REMOVE_ON_FAIL=2000
TOKEN_SYNC_REMOVE_ON_COMPLETE=500
TOKEN_SYNC_REMOVE_ON_FAIL=2000
MV_REFRESH_REMOVE_ON_COMPLETE=100
MV_REFRESH_REMOVE_ON_FAIL=500
BUSINESS_VIEW_BUILD_REMOVE_ON_COMPLETE=100
BUSINESS_VIEW_BUILD_REMOVE_ON_FAIL=500
PROJECT_REPARSE_REMOVE_ON_COMPLETE=500
PROJECT_REPARSE_REMOVE_ON_FAIL=2000

# --- Mapping Pipeline (Schema & Field Extraction) ---
# Strategy selection for policy schema mapping and field extraction.
# Schema mapping strategies: 'GEOJSON' (default)
# Field mapping strategies: 'HEURISTIC-FIELD-MAPPER' (default), 'LLM-FIELD-MAPPER'
MAP_SCHEMAS_METHOD=GEOJSON
MAP_FIELDS_METHOD=HEURISTIC-FIELD-MAPPER

# If using LLM-based field mapping, select the provider and model.
# Available options: gemini, openai, bedrock
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AWS_BEDROCK_REGION=
AWS_BEDROCK_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
AWS_BEDROCK_AUTH_TOKEN=

# --- Worker Autoscaler — maximum concurrency ceiling per queue ---
# The in-process autoscaler raises concurrency when waiting > 100 and lowers
# it when the queue drains. These caps prevent runaway scaling.
# Pattern: WORKER_<QUEUE_BASE_UPPER>_MAX_CONCURRENCY
# Defaults to max(baseline × 4, baseline + 4) when not set.
WORKER_MIRROR_NODE_TOPICS_MAX_CONCURRENCY=
WORKER_MIRROR_NODE_MESSAGES_MAX_CONCURRENCY=
WORKER_MIRROR_NODE_TOKENS_MAX_CONCURRENCY=
WORKER_IPFS_FILES_MAX_CONCURRENCY=
WORKER_POLICY_DECODE_MAX_CONCURRENCY=
WORKER_MAINTENANCE_REFRESH_MVS_MAX_CONCURRENCY=
WORKER_MAINTENANCE_BUILD_BUSINESS_VIEWS_MAX_CONCURRENCY=
WORKER_PROJECT_REPARSE_MAX_CONCURRENCY=

# --- Maintenance ---
MV_REFRESH_INTERVAL=60

# Delay (ms) before re-polling a caught-up topic for new messages.
# Lower = faster detection of new messages but higher Mirror Node load.
# Org topics (discovered via registrantTopicId) poll 3x faster.
MIRROR_NODE_POLL_DELAY=30000

# --- Logging ---
LOG_LEVEL=info
GUARDIAN_ENV=

# --- Frontend (Nuxt) ---
# Server-side SSR fetch base URL — the URL Nuxt uses on the server to call the API.
# In Docker: set to http://api:3030 (internal service name).
# In dev: leave blank — defaults to http://localhost:3030.
NUXT_API_BASE_URL=

# Client-side API base URL — the URL the browser uses to call the API.
# In dev: leave blank — Nuxt proxies /api/v1/** to localhost:3030 via routeRules.
# In production: set to the externally-reachable API URL, e.g. http://<host>:3030.
NUXT_PUBLIC_API_BASE_URL=

# SSE (Server-Sent Events) base URL — must bypass the Nitro dev proxy because
# Nitro buffers the response body, which breaks the text/event-stream protocol.
# In dev: leave blank — defaults to http://localhost:3030 (direct connection).
# In production: set to the same externally-reachable API URL as above.
NUXT_PUBLIC_SSE_API_BASE_URL=

# Feedback widget — Google Apps Script Web App URL that receives feedback
# submissions and appends them to a Google Sheet. Leave blank to hide the
# in-app feedback button. See frontend/google-apps-script/feedback.gs for setup.
NUXT_PUBLIC_FEEDBACK_WEBHOOK_URL=

# Optional shared secret sent with each feedback submission. Must match
# SHARED_SECRET in the Apps Script. A speed bump against random scanners
# (it ships in the public bundle, so it's not a true auth secret).
NUXT_PUBLIC_FEEDBACK_TOKEN=

# --- Guardian event-stream sync (guardian-sync process; OPT-IN) ---
# These variables are ONLY used when the guardian-sync process is started
# explicitly (e.g. start:guardian-sync). They have NO effect on the main
# worker or API processes.
#
# GUARDIAN_INSTANCES — comma-separated unique instance ids (each = one Guardian
# Application Events endpoint). Convention: <label>-<network>, e.g.
# "local-testnet", "deploy-testnet", "acme-mainnet".
#
# An instance is activated only when its TARGET network equals this process's
# HEDERA_NET. The target network defaults to the instance's Hedera net (see
# _HEDERA_NET / _NETWORK below), so:
#   SHARED  (default): several instances on the same Hedera net feed ONE dataset.
#           GUARDIAN_INSTANCES=local-testnet,deploy-testnet + HEDERA_NET=testnet
#           → both stream into the shared "testnet" worker/DB.
#   ISOLATED: give an instance its own dataset via GUARDIAN_<ID>_NETWORK and run a
#           dedicated worker at that HEDERA_NET (needs its own SEED_TOPIC_ID +
#           HEDERA_MIRROR_NODE_URL).
# Leave blank (or unset) to disable guardian-sync entirely.
GUARDIAN_INSTANCES=acme-mainnet
#
# Per-instance configuration — replace <ID> with the composite id
# uppercased and with hyphens replaced by underscores.
# e.g. for "acme-mainnet": <ID> = ACME_MAINNET
#
#   GUARDIAN_<ID>_AEM_URL      (required) Base URL of the Guardian Application
#                               Events Module (AEM) HTTP stream endpoint.
#                               e.g. https://guardian.example.com
#
#   GUARDIAN_<ID>_HEDERA_NET   (optional) Hedera network this Guardian runs on.
#                               Defaults to the suffix after the last '-' in the
#                               id (e.g. "acme-mainnet" → "mainnet").
#
#   GUARDIAN_<ID>_NETWORK      (optional) SE dataset / queue namespace this
#                               instance feeds, matched against HEDERA_NET to
#                               activate it. Defaults to _HEDERA_NET (shared).
#                               Set to a unique value for an isolated dataset.
#
#   GUARDIAN_<ID>_AUTH_HEADER  (optional) Value for the Authorization header
#                               sent with AEM stream requests. Leave blank for
#                               unauthenticated access.
#
#   GUARDIAN_<ID>_EVENTS       (optional) Comma-separated list of event types
#                               to process. Leave blank to process all events.
#
# Worked example for "acme-mainnet":
#   GUARDIAN_ACME_MAINNET_AEM_URL=https://guardian.acme.example.com
#   GUARDIAN_ACME_MAINNET_HEDERA_NET=mainnet
#   GUARDIAN_ACME_MAINNET_AUTH_HEADER=Bearer eyJhbGc...
#   GUARDIAN_ACME_MAINNET_EVENTS=MintEvent,RetireEvent
GUARDIAN_ACME_MAINNET_AEM_URL=https://guardian.acme.example.com
GUARDIAN_ACME_MAINNET_HEDERA_NET=mainnet
GUARDIAN_ACME_MAINNET_AUTH_HEADER=Bearer eyJhbGc...
GUARDIAN_ACME_MAINNET_EVENTS=
#
# Reconnect backoff — initial delay (ms) before retrying a dropped AEM stream
# connection. The guardian-sync subscriber uses exponential backoff starting
# from this value. Increase if the Guardian AEM endpoint rate-limits reconnects.
# Default: 1000
GUARDIAN_SYNC_RECONNECT_BACKOFF_MS=1000
#
# Retention (days) for the guardian_event_log audit table (what events were
# received and what they triggered). Older rows are pruned automatically.
# Default: 7
GUARDIAN_EVENT_LOG_RETENTION_DAYS=7
#
# Mirror node polling guidance: once guardian-sync is active and delivering
# real-time events, the worker's mirror-node polling becomes a background
# catch-up mechanism only. Raise MIRROR_NODE_POLL_DELAY to 300000–600000 ms
# (5–10 minutes) to reduce Mirror Node load while guardian-sync is running.

# =============================================================================
# USER ROLE & AUTH CONFIGURATION
# In production: supply secrets from a secret manager (Vault, AWS SSM, GCP SM).
# =============================================================================

# --- System Database ---
# Separate database on the SAME PostgreSQL server (reuses DB_HOST/PORT/USER/PASSWORD).
# Stores cross-network data: users, API keys, refresh tokens, rate-limit requests,
# dashboards, and quick-filters. Never shares a DB with the per-network data.
#
# Name resolution (when DB_SYSTEM_NAME is blank):
#   GUARDIAN_ENV set   → {GUARDIAN_ENV}_system_{DB_DATABASE}
#   GUARDIAN_ENV empty → system_{DB_DATABASE}
# Set DB_SYSTEM_NAME to use a fully custom database name (overrides computed name).
# Leave blank in all environments unless you need a non-standard DB name.
DB_SYSTEM_NAME=

# --- Auth / JWT ---
# JWT secrets: generate with `openssl rand -hex 32` and store in a secret manager.
# NEVER commit real values — blank = safe-default that prevents the service from
# issuing valid tokens until real secrets are supplied.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Access token lifetime in minutes (default: 15 min — short-lived for quick revocation).
ACCESS_TOKEN_TTL_MINUTES=15

# Refresh token lifetime in days (default: 7 d — rotating refresh with reuse detection).
REFRESH_TOKEN_TTL_DAYS=7

# Absolute session TTL in days regardless of activity (default: 30 d).
SESSION_ABSOLUTE_TTL_DAYS=30

# bcrypt work factor for password hashing (only used if argon2 build fails on the host).
# Increase to 13–14 on hardware that can afford > 100 ms per hash.
BCRYPT_ROUNDS=12

# Password pepper: random 32-byte hex string, stored in env / secret manager only.
# Applied before hashing so a DB leak alone cannot crack passwords.
PASSWORD_PEPPER=

# API key pepper: same principle, separate value from PASSWORD_PEPPER.
API_KEY_PEPPER=

# Cookie topology: same-domain reverse-proxy (frontend + API share the same domain).
# Phase 1 does NOT wire cookie middleware — these are placeholders consumed later.
# AUTH_COOKIE_DOMAIN: leave blank in dev (defaults to request host); set in prod.
# AUTH_COOKIE_SAMESITE: Lax (safe default for same-domain). Options: Strict | Lax | None.
# AUTH_COOKIE_SECURE: true in prod (requires HTTPS); false only in local dev.
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=true

# --- Rate Limits ---
# Global per-user / per-API-key quotas (never per-network).
# Leave blank to use code defaults (system_user: 1000/h, admin: 10000/h, max: 10000/h).
RATE_LIMIT_SYSTEM_USER_PER_HOUR=
RATE_LIMIT_ADMIN_PER_HOUR=
RATE_LIMIT_MAX_QUOTA=

# Login brute-force lockout: account locked after N consecutive failures for M minutes.
LOGIN_MAX_FAILURES=10
LOGIN_LOCK_MINUTES=15

# --- Public-data access control (Phase 4 Part B) ---
# OFF by default. When true, network-scoped data endpoints (/api/v1/:network/...)
# require EITHER the trusted frontend (browser Origin in API_CORS_ORIGINS, or the
# FRONTEND_SHARED_SECRET header for SSR server-to-server) OR a valid API key.
# Guests browse via the frontend; programmatic/scraping callers must use a key.
# FRONTEND_SHARED_SECRET must be set to the SAME value on BOTH the API process and
# the frontend (Nuxt) process. Generate: openssl rand -hex 32 (or node crypto).
DATA_ACCESS_ENFORCE=false
FRONTEND_SHARED_SECRET=

# Max ACTIVE API keys a single user may hold (configurable; default 3).
# Enforced atomically when API-key creation is built (Phase 5).
API_KEY_MAX_ACTIVE_PER_USER=3

# Redis-backed throttler. OFF by default — when true, every request is rate-limited
# per hour: by user (apiQuotaPerHour or role default) when authenticated, else by IP
# (RATE_LIMIT_GUEST_PER_HOUR). Redis errors fail OPEN. Needs Redict running.
# Per-API-key limiting also requires DATA_ACCESS_ENFORCE=true (sets the principal).
RATE_LIMIT_ENFORCE=false
RATE_LIMIT_GUEST_PER_HOUR=600

# --- Initial Admin (break-glass) ---
# Email + password for the first admin account seeded on boot.
# Phase 1 placeholder — consumed by the admin-seeder in a later phase.
# Set via secret manager in prod; leave blank in dev until the seeder is active.
# Admin-created users are trusted (emailVerifiedAt set, mustChangePassword=true).
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# --- SMTP (placeholder — wired in a later phase) ---
# Phase 1: these values are parsed into config but no mailer module is registered yet.
# Used for: email verification on self-signup, forgot-password flow.
# Self-signup users get role=system_user, isActive=true, emailVerifiedAt=null —
# they cannot sign in until they click the verification link.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Set SMTP_SECURE=true for port 465 (implicit TLS); false for STARTTLS (port 587).
SMTP_SECURE=false
# DEV ONLY: log verification / password-reset LINKS to the API console so flows can
# be tested without a deliverable mailbox (e.g. SES sandbox). The link is a
# credential — NEVER set true in production.
MAIL_LOG_LINKS=false

# --- Transactional email queue (BullMQ on Redict) ---
# When true, verification + password-reset emails are enqueued to the 'send-email'
# BullMQ queue (retries + durability, off the HTTP request path), consumed by a
# processor inside the API process. When false (default), or if Redict is
# unreachable at enqueue time, emails are sent INLINE via the existing
# fire-and-forget path — the site never 500s because the queue is down.
MAIL_QUEUE_ENABLED=false

# --- Frontend public base URL ---
# Base URL of the public frontend used to construct email verification and
# password-reset links sent to users (e.g. https://app.example.com).
# Must have NO trailing slash — the verify/reset path is appended directly,
# e.g. APP_PUBLIC_URL/auth/verify?token=...
# Leave blank in dev (links will be built from an empty base, which is safe
# for local testing when the frontend runs at the same origin).
# In production: set to the externally-reachable frontend origin.
# Read in the API via ConfigService.get<string>('app.auth.publicAppUrl').
APP_PUBLIC_URL=

# Minimum seconds between verification-email resends, per user (default 300 = 5 min).
RESEND_VERIFICATION_COOLDOWN_SECONDS=300