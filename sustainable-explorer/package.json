{
    "name": "@guardian/sustainable-explorer",
    "version": "1.0.0",
    "description": "Sustainable Explorer - Indexing and exploration service for Guardian environmental assets",
    "private": true,
    "license": "Apache-2.0",
    "scripts": {
        "start:api": "node dist/src/api/main.js",
        "start:worker": "node dist/src/worker/main.js",
        "start:guardian-sync": "node dist/src/guardian-sync/main.js",
        "build": "nest build",
        "dev:api": "nest start --watch --entryFile src/api/main",
        "dev:worker": "nest start --watch src/worker/main.ts",
        "dev:guardian-sync": "nest start --watch --entryFile src/guardian-sync/main",
        "infra:up": "docker compose -f docker-compose-dev.yml up -d",
        "infra:down": "docker compose -f docker-compose-dev.yml down",
        "infra:reset": "docker compose -f docker-compose-dev.yml down -v && docker compose -f docker-compose-dev.yml up -d",
        "lint": "eslint \"{src,test}/**/*.ts\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "dependencies": {
        "@nestjs/bullmq": "^11.0.0",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/swagger": "^11.0.0",
        "@nestjs/typeorm": "^11.0.0",
        "axios": "^1.7.0",
        "bullmq": "^5.25.0",
        "cids": "^1.1.9",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "dotenv": "^17.4.0",
        "ioredis": "^5.4.0",
        "jszip": "^3.10.1",
        "pg": "^8.13.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "swagger-ui-express": "^5.0.1",
        "typeorm": "^0.3.20"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@types/jest": "^30.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.14.0",
        "@types/pg": "^8.20.0",
        "jest": "^30.3.0",
        "source-map-support": "^0.5.21",
        "ts-jest": "^29.4.9",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.5.0"
    }
}
