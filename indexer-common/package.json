{
    "author": "Hashgraph <guardian@hashgraph.com>",
    "dependencies": {
        "@indexer/interfaces": "workspace:*",
        "@mikro-orm/core": "6.6.15",
        "@mikro-orm/migrations-mongodb": "6.6.15",
        "@mikro-orm/mongodb": "6.6.15",
        "@nestjs/common": "^11.1.24",
        "@nestjs/core": "^11.1.24",
        "@nestjs/microservices": "^11.1.24",
        "cross-blob": "^2.0.1",
        "dotenv": "16.6.1",
        "jszip": "3.10.1",
        "mongodb": "6.21.0",
        "nats": "2.29.3",
        "reflect-metadata": "0.2.2",
        "rxjs": "7.8.2"
    },
    "description": "Common package share cross all services",
    "devDependencies": {
        "@types/express": "5.0.6",
        "@types/glob": "^8.1.0",
        "@types/node": "24.13.3",
        "tslint": "^6.1.3",
        "typescript": "^5.8.3"
    },
    "exports": {
        ".": "./dist/index.js",
        "./entities": "./dist/entities.js",
        "./dist/*": "./dist/*",
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "name": "@indexer/common",
    "sideEffects": [
        "./dist/entity/**/*.js"
    ],
    "scripts": {
        "build": "tsc",
        "build:prod": "tsc --project tsconfig.production.json",
        "dev": "tsc -w",
        "lint": "tslint --config ../tslint.json --project .",
        "prepack": "npm run build:prod",
        "test": "mocha tests/**/*.test.js --reporter mocha-junit-reporter --reporter-options mochaFile=../test_results/indexer-common.xml --exit",
        "test:local": "mocha tests/**/*.test.js --exit",
        "test:stability": "mocha tests/stability.test.js"
    },
    "type": "module",
    "version": "3.6.0"
}
