{
    "author": "Hashgraph <guardian@hashgraph.com>",
    "dependencies": {
        "@indexer/interfaces": "workspace:*",
        "@mikro-orm/core": "6.4.16",
        "@mikro-orm/migrations-mongodb": "6.4.16",
        "@mikro-orm/mongodb": "6.4.16",
        "@nestjs/common": "^11.1.24",
        "@nestjs/core": "^11.1.24",
        "@nestjs/microservices": "^11.1.24",
        "cross-blob": "^2.0.1",
        "dotenv": "^16.0.0",
        "jszip": "^3.7.1",
        "module-alias": "^2.2.2",
        "mongodb": "6.21.0",
        "nats": "^2.6.1",
        "reflect-metadata": "^0.2.2"
    },
    "description": "Common package share cross all services",
    "devDependencies": {
        "@types/express": "^5.0.1",
        "@types/glob": "^8.1.0",
        "@types/node": "^22.15.19",
        "mocha-junit-reporter": "^2.0.2",
        "tslint": "^6.1.3",
        "typescript": "^5.8.3"
    },
    "files": [
        "dist"
    ],
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "exports": {
        ".": "./dist/index.js",
        "./entities": "./dist/entities.js",
        "./dist/*": "./dist/*",
        "./package.json": "./package.json"
    },
    "sideEffects": [
        "./dist/entity/**/*.js"
    ],
    "name": "@indexer/common",
    "scripts": {
        "build": "tsc",
        "build:prod": "tsc --project tsconfig.production.json",
        "dev": "tsc -w",
        "lint": "tslint --config ../tslint.json --project .",
        "prepack": "npm run build:prod",
        "test": "mocha tests/**/*.test.js --reporter mocha-junit-reporter --reporter-options mochaFile=../test_results/indexer-common.xml --exit",
        "test:local": "mocha tests/**/*.test.js --exit",
        "test:stability": "mocha tests/stability.test.js"
    },
    "type": "module",
    "version": "3.6.0"
}
