# =============================================================================
# Sustainability Atlas — Frontend (Nuxt 3) environment
# Copy to `.env` and adjust. In Docker these are set in docker-compose.yml.
# =============================================================================

# --- API base URLs ---
# SSR (server-side) API base — the Nuxt server calls this during rendering.
# Leave blank to use the code default (http://localhost:3030). In Docker set to
# http://api:3030 (Docker DNS).
NUXT_API_BASE_URL=

# Client-side API base — used by the browser after hydration. Must be reachable
# from end-user machines. Leave blank in dev to use the Nuxt proxy.
NUXT_PUBLIC_API_BASE_URL=

# SSE base URL — must bypass the Nitro proxy (Nitro buffers text/event-stream).
# Must be publicly reachable. Leave blank to use the code default
# (http://localhost:3030).
NUXT_PUBLIC_SSE_API_BASE_URL=

# --- Trusted-frontend shared secret (server-only) ---
# Sent as the X-Frontend-Key header on SSR (server-to-server) API calls so the
# API's DataAccessGuard recognises the Nuxt server as the trusted frontend and
# exempts it from the API-key gate + rate limits. MUST be the SAME value as the
# API process's FRONTEND_SHARED_SECRET (backend .env). Read server-side ONLY —
# never rename to NUXT_PUBLIC_* (that would ship it to the browser).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FRONTEND_SHARED_SECRET=
