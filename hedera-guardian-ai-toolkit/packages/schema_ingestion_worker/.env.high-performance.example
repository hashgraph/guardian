# Schema Ingestion Worker - High Performance Profile (32+ GB systems)
#
# For systems with 32 GB+ RAM and ample Docker Desktop allocation.
# These were the previous defaults before the 16 GB optimization.
# Copy to .env or pass as: docker compose --env-file .env.high-performance run --rm schema-ingestion-worker
#
# NOTE: Also increase Docker mem_limit to 6g in docker-compose.yml or via override:
#   docker compose run --rm -m 6g schema-ingestion-worker

SCHEMA_INGESTION_EMBEDDING_BATCH_SIZE=500
SCHEMA_INGESTION_ONNX_INFERENCE_BATCH_SIZE=64
SCHEMA_INGESTION_VECTOR_UPSERT_BATCH_SIZE=100

# IMPORTANT: With onnx_batch=64 and embedding_batch=500, the default 300s
# embedding timeout has only ~1.07x margin on slower hardware. Increase to
# 350-400s if you experience timeouts.
SCHEMA_INGESTION_EMBEDDING_TIMEOUT=400
SCHEMA_INGESTION_UPSERT_TIMEOUT=60
