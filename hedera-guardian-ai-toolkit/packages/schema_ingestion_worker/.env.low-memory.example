# Schema Ingestion Worker - Low Memory Profile (8 GB systems)
#
# For systems with 8 GB RAM and limited Docker Desktop allocation.
# Copy to .env or pass as: docker compose --env-file .env.low-memory run --rm schema-ingestion-worker
#
# NOTE: Also reduce Docker mem_limit to 2g in docker-compose.yml or via override:
#   docker compose run --rm -m 2g schema-ingestion-worker
#
# On 8 GB systems, consider reducing Qdrant mem_limit to 2g as well
# to avoid combined container pressure exceeding available memory.

SCHEMA_INGESTION_EMBEDDING_BATCH_SIZE=128
SCHEMA_INGESTION_ONNX_INFERENCE_BATCH_SIZE=16
SCHEMA_INGESTION_VECTOR_UPSERT_BATCH_SIZE=25

# Timeouts (defaults are generous enough for this profile)
SCHEMA_INGESTION_EMBEDDING_TIMEOUT=300
SCHEMA_INGESTION_UPSERT_TIMEOUT=60
