# Low-Memory Profile for 8-12GB RAM systems (Mac/Linux/Windows)
# Copy to .env and adjust as needed
#
# Use this profile for:
# - MacBook Air or older Macs with 8GB RAM
# - Systems with 8-12GB RAM
# - Docker Desktop with limited memory allocation (6GB+)
#
# Docker Desktop users: also use the low-memory compose override:
#   docker compose -f docker-compose.yml -f docker-compose.low-memory.yml run --rm document-ingestion-worker
# This reduces container mem_limits (Qdrant 2g, worker 6g) to fit within
# the ~8GB available after Windows/macOS VM overhead.
#
# WARNING: Surya formula enrichment requires 16GB+ RAM.
# On 8-12GB systems, Surya is disabled and Docling's built-in formula model is used instead.
#
# NOTE: Documents that exceed the subprocess memory limit will fail (no automatic retry).
# Failed documents are logged and skipped. Re-run with a higher limit if needed.

# =============================================================================
# PARALLEL PROCESSING - MOST IMPORTANT FOR MEMORY
# =============================================================================

# Process one document at a time (matches default: 1)
# Each document loads the full ML pipeline into memory
DOCUMENT_INGESTION_MAX_PARALLEL_FILES=1

# Per-subprocess memory limit (GB) — kills subprocess if RSS exceeds this
# psutil is bundled as a required dependency — no extra install needed.
# On 8GB systems:  set to 6 (leaves ~2GB for system)
# On 12GB systems with Docker: docker-compose.low-memory.yml sets its own value (5GB)
#                  set to 8 when running locally (no container overhead)
DOCUMENT_INGESTION_SUBPROCESS_MEMORY_LIMIT_GB=6

# CPU threads (matches default: 2)
DOCUMENT_INGESTION_NUM_THREADS=2

# =============================================================================
# BATCH SIZES - REDUCE MEMORY PER OPERATION
# =============================================================================

# Embedding batch size (standard default: 5, unchanged for local low-memory)
# Docker low-memory override uses smaller value (3) due to VM overhead
DOCUMENT_INGESTION_EMBEDDING_BATCH_SIZE=5

# Vector upsert batch size (default: 20)
DOCUMENT_INGESTION_VECTOR_UPSERT_BATCH_SIZE=20

# ML model batch sizes (standard default: 2, unchanged for local low-memory)
# Docker low-memory override uses smaller value (1) due to VM overhead
DOCUMENT_INGESTION_LAYOUT_BATCH_SIZE=2
DOCUMENT_INGESTION_OCR_BATCH_SIZE=2
DOCUMENT_INGESTION_TABLE_BATCH_SIZE=2

# =============================================================================
# PDF RENDERING
# =============================================================================

# Page rendering scale (default: 2.0)
# Do NOT increase on 8-12GB systems - higher values require significantly more memory
DOCUMENT_INGESTION_PDF_IMAGES_SCALE=2.0

# =============================================================================
# SURYA FORMULA ENRICHMENT - DISABLED FOR 8-12GB
# =============================================================================

# Surya formula enrichment is DISABLED on 8-12GB systems.
# The subprocess + Surya pipeline peaks at ~8-10GB for complex documents,
# which exceeds available memory after OS/Docker overhead on 8-12GB hardware.
# Docling's built-in formula model will be used instead.
DOCUMENT_INGESTION_USE_SURYA_FORMULA_ENRICHMENT=false

# =============================================================================
# HARDWARE ACCELERATION
# =============================================================================

# Force CPU - more stable and predictable on low-memory systems
# Options: auto, cuda, mps, cpu
DOCUMENT_INGESTION_ACCELERATOR_DEVICE=cpu

# =============================================================================
# TABLE POSTPROCESSING
# =============================================================================

# Detect and merge tables split across page boundaries (default: true)
# DOCUMENT_INGESTION_MERGE_SPLIT_TABLES=true

# Keep each table as a separate chunk (default: true)
# DOCUMENT_INGESTION_ISOLATE_TABLE_CHUNKS=true

# =============================================================================
# STANDARD SETTINGS (unchanged)
# =============================================================================

DOCUMENT_INGESTION_QDRANT_URL=http://localhost:6333
DOCUMENT_INGESTION_QDRANT_COLLECTION_NAME=methodology_documents
DOCUMENT_INGESTION_DATA_DIR=data
DOCUMENT_INGESTION_MODE=override

# =============================================================================
# OPTIONAL: FURTHER MEMORY REDUCTION
# =============================================================================

# Disable table structure extraction to save ~1GB (TableFormer model)
# Only use if you don't need table extraction
# DOCUMENT_INGESTION_DO_TABLE_STRUCTURE=false
