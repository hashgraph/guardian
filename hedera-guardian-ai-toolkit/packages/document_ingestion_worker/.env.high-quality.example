# High Quality Profile for 16+ GB RAM systems
# Copy to .env and adjust as needed
#
# Use this profile for:
# - Systems with 16+ GB RAM and GPU acceleration
# - MacBook Pro 16GB+ with Apple Silicon (MPS)
# - Docker Desktop with 10GB+ memory allocation
#
# ============================================================================
# DOCKER DESKTOP WARNING (Windows/macOS)
# ============================================================================
# Docker Desktop on Windows/macOS reserves significant memory for WSL2/hypervisor:
#   - Windows (WSL2): ~4-6GB overhead
#   - macOS (hypervisor): ~2-4GB overhead
#
# For a 16GB system running Docker Desktop on Windows:
#   - Total RAM: 16GB
#   - WSL2/Docker overhead: ~5GB
#   - Available to container: ~10-11GB
#   - docker-compose.yml mem_limit: 10g (enforced)
#
# If you experience silent failures or crashes:
#   1. Check Docker Desktop memory allocation (Settings > Resources)
#   2. Reduce PDF_IMAGES_SCALE from 4.0 to 2.5
#   3. Reduce batch sizes (SURYA_BATCH_SIZE=2, LAYOUT_BATCH_SIZE=2)
#   4. Monitor with: docker stats document-ingestion-worker
# ============================================================================
#
# This profile prioritizes HIGH QUALITY formula recognition over throughput.
# - Higher resolution page rendering (4.0 scale)
# - Single-file processing to maintain memory headroom (~9GB per document)
#
# ACTUAL MEMORY USAGE (approximate):
# - Base pipeline: ~2-3GB
# - PDF parsing with PDF_IMAGES_SCALE=4.0: ~4-6GB peak
# - Surya formula enrichment: ~2-3GB additional
# - Peak per document: ~8-9GB
#
# Recommended minimum available memory: 10GB (after OS/Docker overhead)

# =============================================================================
# PARALLEL PROCESSING
# =============================================================================

# Single file processing for High Quality memory headroom (default: 1)
# High Quality uses ~9GB per document; parallel would exceed 16GB (9GB × 2 = 18GB)
DOCUMENT_INGESTION_MAX_PARALLEL_FILES=1

# Moderate CPU threads (default: 2)
DOCUMENT_INGESTION_NUM_THREADS=4

# Per-subprocess memory limit (GB) — optional for 16+ GB systems
# Uncomment and set if experiencing runaway memory on Windows
# DOCUMENT_INGESTION_SUBPROCESS_MEMORY_LIMIT_GB=12

# =============================================================================
# BATCH SIZES
# =============================================================================

# Embedding batch size (default: 5)
# Increased for faster processing with more memory
DOCUMENT_INGESTION_EMBEDDING_BATCH_SIZE=25

# Vector upsert batch size (default: 20)
DOCUMENT_INGESTION_VECTOR_UPSERT_BATCH_SIZE=50

# ML model batch sizes (default: 2)
# Increased for better throughput
DOCUMENT_INGESTION_LAYOUT_BATCH_SIZE=4
DOCUMENT_INGESTION_OCR_BATCH_SIZE=4
DOCUMENT_INGESTION_TABLE_BATCH_SIZE=4

# =============================================================================
# PDF RENDERING (High Quality)
# =============================================================================

# High Quality page rendering scale (default: 2.0)
# 4.0 significantly improves formula recognition for complex equations,
# subscripts, and scientific notation
DOCUMENT_INGESTION_PDF_IMAGES_SCALE=4.0

# =============================================================================
# SURYA FORMULA ENRICHMENT (High Quality)
# =============================================================================

# High Quality Surya settings for 16+ GB systems
DOCUMENT_INGESTION_SURYA_BATCH_SIZE=4

# Upscale factor not needed at high resolution (default: 1.5)
# When using high pdf_images_scale (4.0), additional upscaling is unnecessary
DOCUMENT_INGESTION_SURYA_UPSCALE_FACTOR=1.0

# =============================================================================
# HARDWARE ACCELERATION
# =============================================================================

# Hardware acceleration (auto-detects best available: CUDA > MPS > CPU)
# Options: auto, cuda, mps, cpu
DOCUMENT_INGESTION_ACCELERATOR_DEVICE=auto

# =============================================================================
# TABLE POSTPROCESSING (High Quality)
# =============================================================================

# Detect and merge tables split across page boundaries (default: true)
# Recommended for methodology documents with large tables spanning multiple pages
DOCUMENT_INGESTION_MERGE_SPLIT_TABLES=true

# Keep each table as a separate chunk (default: true)
# Prevents HybridChunker from merging multiple tables under the same heading
DOCUMENT_INGESTION_ISOLATE_TABLE_CHUNKS=true

# =============================================================================
# STANDARD SETTINGS (unchanged)
# =============================================================================

DOCUMENT_INGESTION_QDRANT_URL=http://localhost:6333
DOCUMENT_INGESTION_QDRANT_COLLECTION_NAME=methodology_documents
DOCUMENT_INGESTION_DATA_DIR=data
DOCUMENT_INGESTION_MODE=override
