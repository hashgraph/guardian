{
    "compilerOptions": {
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "isolatedModules": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "noUnusedLocals": true,
        "noUnusedParameters": false,
        "outDir": "./dist",
        "paths": {
            "#constants": [
                "./src/constants/index.js"
            ]
        },
        "rootDir": "./src",
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "target": "ES2023"
    },
    "exclude": [
        "node_modules",
        "**/*.spec.ts"
    ],
    "include": [
        "./src/**/*"
    ]
}